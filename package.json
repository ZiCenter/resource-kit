{
  "name": "@zicenter/resource-kit",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./i18n/provider": {
      "types": "./dist/i18n/provider.d.ts",
      "import": "./dist/i18n/provider.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zicenter/form-kit": "github:ZiCenter/form-kit#main"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.0.0",
    "axios": "^1.0.0",
    "date-fns": "^3.0.0 || ^4.0.0",
    "i18next": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@zicenter/form-kit"
    ]
  }
}
